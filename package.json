{
  "name": "rbook",
  "version": "1.0.0",
  "description": "A simple static book site generator",
  "main": "bin/rbook.js",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "rbook": "./bin/rbook.js"
  },
  "scripts": {
    "clean": "rm -rf packages/*/dist src/online_judge/dist site/widgets/code_template_filter/dist",
    "build:packages": "tsc -p packages/rbook-markdown && tsc -p packages/rbook-core && tsc -p packages/rbook-search && tsc -p packages/rbook-server && tsc -p packages/rbook-cli && tsc -p src/online_judge",
    "build": "npm run build:packages && bash site/build.sh",
    "build:index": "node packages/rbook-search/dist/buildIndex.js",
    "build:all": "npm run build && npm run build:index",
    "build:runtime": "node packages/rbook-server/dist/buildRuntime.js",
    "start:runtime": "npm run build:runtime && node packages/rbook-server/dist/serve.js",
    "serve": "npm run start:runtime",
    "serve:dev": "npm run serve",
    "dev": "npm run serve",
    "test:api": "node scripts/test-ai-api-contract.mjs",
    "typecheck": "npm run build:packages && tsc -p site/widgets/code_template_filter"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "fastify": "^5.8.5",
    "fuse.js": "^7.3.0",
    "glob": "^11.1.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "katex": "^0.16.9",
    "markdown-it": "^13.0.1",
    "markdown-it-abbr": "^1.0.4",
    "markdown-it-anchor": "^8.6.7",
    "markdown-it-codetabs": "^1.2.0",
    "markdown-it-container": "^3.0.0",
    "markdown-it-emoji": "^2.0.2",
    "markdown-it-footnote": "^3.0.2",
    "markdown-it-iframe": "^1.0.0",
    "markdown-it-image-figures": "^2.1.1",
    "markdown-it-imsize": "^2.0.1",
    "markdown-it-inline-comments": "^1.0.1",
    "markdown-it-ins-del": "^0.1.1",
    "markdown-it-kbd": "^2.0.0",
    "markdown-it-link-attributes": "^4.0.1",
    "markdown-it-mark": "^3.0.0",
    "markdown-it-mathjax": "^2.0.0",
    "markdown-it-multimd-table": "^4.0.0",
    "markdown-it-shiki": "^0.9.0",
    "markdown-it-sub": "^1.0.0",
    "markdown-it-sup": "^1.0.0",
    "markdown-it-task-checkbox": "^1.0.6",
    "markdown-it-texmath": "^1.0.0",
    "markdown-it-toc-done-right": "^4.2.0",
    "pangu": "^4.0.7",
    "prismjs": "^1.20.0",
    "pug": "^3.0.3",
    "sass": "^1.93.2",
    "twemoji": "^14.0.2",
    "ws": "^8.18.3"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "keywords": [
    "markdown",
    "static-site-generator",
    "book",
    "pug"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@jsonlee_12138/markdown-it-mermaid": "^0.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.1",
    "@types/pug": "^2.0.10",
    "@vitejs/plugin-vue": "^6.0.2",
    "@wekanteam/markdown-it-mermaid": "^0.6.4",
    "add": "^2.0.6",
    "archiver": "^7.0.1",
    "chalk": "^5.6.2",
    "cheerio": "^1.1.2",
    "ejs": "^3.1.10",
    "markdown-it-mermaid": "^0.2.5",
    "mermaid": "^11.12.2",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "uslug": "^1.0.4",
    "vis-network": "^10.0.2",
    "vite": "^7.2.4",
    "vite-plugin-ejs": "^1.7.0",
    "vue": "^3.5.24",
    "vue-toastification": "^2.0.0-rc.5",
    "yarn": "^1.22.22"
  }
}
